rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función helper para verificar autenticación
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Función helper para verificar que el usuario es el dueño de los datos
    function isOwner(providerId) {
      return isAuthenticated() && request.auth.uid == providerId;
    }

    // Colección de Profesionales (Providers)
    // El providerId del path ES el UID del usuario autenticado.
    match /providers/{providerId} {
      allow read, write: if isOwner(providerId);
      
      // Subcolección de Pacientes — el path ya garantiza el aislamiento por provider.
      match /patients/{patientId} {
        allow read, update, delete: if isOwner(providerId);
        allow create: if isOwner(providerId);
        
        // Subcolección de Turnos (Appointments)
        match /appointments/{appointmentId} {
          allow read, update, delete: if isOwner(providerId);
          allow create: if isOwner(providerId);
        }
        
        // Subcolección de Pagos (Payments)
        match /payments/{paymentId} {
          allow read, update, delete: if isOwner(providerId);
          allow create: if isOwner(providerId);
        }
        
        // Subcolección de Turnos Recurrentes (Recurring Appointments)
        match /recurring_appointments/{recurringAppointmentId} {
          allow read, update, delete: if isOwner(providerId);
          allow create: if isOwner(providerId);
        }
      }
    }
    
    // Reglas para CollectionGroup Queries
    // Necesarias para buscar subcolecciones sin conocer el path completo.
    match /{path=**}/appointments/{appointmentId} {
      allow read: if isOwner(resource.data.providerId);
    }
    
    match /{path=**}/payments/{paymentId} {
      allow read: if isOwner(resource.data.providerId);
    }
    
    match /{path=**}/recurring_appointments/{recurringAppointmentId} {
      allow read: if isOwner(resource.data.providerId);
    }
    
    // Colección de Comunicaciones/Logs (WhatsApp etc)
    match /communications/{commId} {
      allow read, update, delete: if isOwner(resource.data.providerId);
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.providerId;
    }
  }
}
